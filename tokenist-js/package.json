{
  "name": "tokenist-js",
  "version": "0.2.1",
  "author": "Tokenist <tokenistdev@gmail.com>",
  "license": "MIT",
  "keywords": [
    "llm",
    "agents",
    "guardrails",
    "ai"
  ],
  "description": "Node.js client for the Tokenist API — token tracking, cost guardrails, and user management for OpenAI integrations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --testPathPattern=tests/ --testPathIgnorePatterns=tests/integration",
    "test:watch": "jest --watch --testPathPattern=tests/ --testPathIgnorePatterns=tests/integration",
    "test:coverage": "jest --coverage --testPathPattern=tests/ --testPathIgnorePatterns=tests/integration",
    "test:integration": "jest --config jest.integration.config.js --runInBand --forceExit",
    "test:integration:watch": "jest --config jest.integration.config.js --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  }
}
