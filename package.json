{
  "name": "tokenist-js",
  "version": "0.1.0",
  "author": "Tokenist <tokenistdev@gmail.com>",
  "license": "MIT",
  "keywords": [
    "llm",
    "agents",
    "guardrails",
    "ai"
  ],
  "description": "Node.js client for the Tokenist.dev API — token tracking, cost guardrails, and user management LLMs and agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "init": "rm -rf .wrangler && npm install && wrangler d1 execute tokenist-db --local --file=./schema.sql && wrangler d1 execute tokenist-db --local --file=./seed-pricing.sql",
    "build": "tsc",
    "dev": "wrangler dev src/worker.ts --port 8081 --ip 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "bash scripts/run-integration-tests.sh",
    "example:log-with-fetch": "tsx examples/log-with-fetch.ts"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "js-tiktoken": "^1.0.15",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/node": "^25.2.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.67.0"
  },
  "engines": {
    "node": ">=18"
  }
}
